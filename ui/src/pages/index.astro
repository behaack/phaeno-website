---
import Layout from '@/layouts/Layout.astro';
import Tagline from '@/components/home-page-sections/Tagline.astro';
import SEOMeta from '@/components/meta-data-helpers/SEOMeta.astro';
import PerformanceMetrics from '@/components/PerformanceMetrics.astro';

const homeTitle = 'Phaeno | Full-Length RNA Sequencing with Short-Read NGS';
const homeDescription = 'Phaeno delivers full-length, isoform-resolved RNA sequencing with short-read NGS instruments and ML-ready molecule-level outputs.';
const siteUrl = new URL('/', Astro.site).href;
const organizationStructuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}#organization`,
      name: 'Phaeno',
      legalName: 'Phaeno Inc.',
      url: siteUrl,
      logo: new URL('/images/phaeno-socialmedia-splash.webp', Astro.site).href,
      image: new URL('/images/phaeno-socialmedia-splash.webp', Astro.site).href,
      description: homeDescription,
      email: 'info@phaenobiotech.com',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '5270 California Avenue, Suite 300',
        addressLocality: 'Irvine',
        addressRegion: 'CA',
        postalCode: '92617',
        addressCountry: 'US',
      },
      sameAs: [
        'https://www.linkedin.com/company/phaeno-biotech/',
        'https://www.youtube.com/@phaenobiotech',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      name: 'Phaeno',
      url: siteUrl,
      publisher: { '@id': `${siteUrl}#organization` },
    },
  ],
};

const platformFeatures = [
  {
    id: 'clear-signal-architecture',
    search: 'PSeq Clear-Signal Architecture signal-first RNA data',
    eyebrow: '01 / Signal',
    title: 'PSeq Clear-Signal Architecture™',
    summary: 'Full-length 5′–3′ isoform reconstruction, including UTRs, constrained by reads assigned to each captured molecular template.',
  },
  {
    id: 'individual-molecules',
    search: 'A more direct view of individual RNA isoforms with PSeq',
    eyebrow: '02 / Molecules',
    title: 'A more direct view of individual isoforms',
    summary: 'With sufficient depth and coverage, molecule-assigned reads support isoform-level measurement without reconstructing structure from pooled fragments.',
  },
  {
    id: 'automated-pipeline',
    search: 'Automated molecule-aware PSeq pipeline',
    eyebrow: '03 / Workflow',
    title: 'Automated, molecule-aware processing',
    summary: 'Preprocessing and quality control prepare reads for molecule-specific assignment before transcript assembly.',
  },
  {
    id: 'ml-ready-outputs',
    search: 'Built for downstream machine learning',
    eyebrow: '04 / Intelligence',
    title: 'Built for downstream machine learning',
    summary: 'Structured, molecule-level features preserve isoform detail for use in ML models and established analysis tools.',
  },
];

const performanceHighlights = [
  {
    value: '>87%',
    label: 'Rare isoform sensitivity',
    detail: 'at <0.01% abundance',
  },
  {
    value: '>94%',
    label: 'Full-length isoform recovery',
  },
  {
    value: '<2 hrs',
    label: 'Hands-on time per sample',
  },
  {
    value: '<24 hrs',
    label: 'Library-to-FASTA turnaround',
  },
];
---
<Layout>
  <SEOMeta 
    slot="head"
    title={homeTitle}
    description={homeDescription}
    documentType="Web Page"
    searchTitle="Home"
    searchKeywords="PSeq phased sequencing full-length RNA sequencing isoform-resolved RNA whole-molecule RNA molecule-level transcriptomics short-read NGS ML-ready outputs machine learning feature matrices"
  />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(organizationStructuredData)} />

  <main class="home-main" id="main" tabindex="-1">
    <Tagline />

    <section class="platform-section">
      <div class="platform-intro">
        <div>
          <p class="section-kicker" data-phaeno-search-ignore>The discovery layer</p>
          <h2
            id="pseq-intro"
            data-phaeno-search="PSeq phased sequencing platform overview"
            data-phaeno-search-summary="PSeq exposes molecular phenotype by resolving isoforms and transcript-specific regulation that gene-level summaries miss."
            data-phaeno-search-keywords="PSeq phased sequencing platform isoform regulation molecular phenotype gene counts"
          >Phaeno's PSeq™ maps the molecular phenotype.</h2>
        </div>

        <div class="platform-copy">
          <p>Gene-level counts compress biology. Isoforms capture splicing, promoter usage, UTR variation, and transcript-specific regulation—often the true functional drivers.</p>
          <p class="platform-thesis">PSeq reveals the biological drivers obscured by gene-level summaries and incomplete isoform resolution.</p>
          <div class="platform-links" data-phaeno-search-ignore>
            <a class="platform-links__featured" href="/multi-omics">Explore PSeq + multi-omics <span aria-hidden="true">→</span></a>
            <a href="/why-isoforms-matter">Why isoforms matter <span aria-hidden="true">→</span></a>
          </div>
        </div>
      </div>

      <div class="feature-grid">
        {platformFeatures.map((feature, index) => (
          <article
            class:list={['feature-card', { 'feature-card--lead': index === 0 }]}
            data-motion-reveal
            data-motion-delay={index * 50}
          >
            <p class="feature-card__eyebrow" data-phaeno-search-ignore>{feature.eyebrow}</p>
            <h3
              id={feature.id}
              data-phaeno-search={feature.search}
              data-phaeno-search-summary={feature.summary}
            >
              {index === 0
                ? <><span class="feature-card__title-line">PSeq Clear-Signal</span><br />Architecture™</>
                : feature.title}
            </h3>
            <p>{feature.summary}</p>
          </article>
        ))}
      </div>

      <div class="platform-cta" data-phaeno-search-ignore>
        <div class="platform-cta__inner">
          <div class="platform-cta__content">
            <div>
              <p class="section-kicker">From reads to resolved biology</p>
              <p>See how PSeq chemistry and software recover complete RNA molecules on standard NGS platforms.</p>
            </div>
            <a href="/technology">Explore PSeq technology <span aria-hidden="true">→</span></a>
          </div>

          <dl class="platform-metrics" aria-label="PSeq performance highlights">
            {performanceHighlights.map((metric) => (
              <div class="platform-metric">
                <dt>
                  {metric.label}
                  {metric.detail && <span>{metric.detail}</span>}
                </dt>
                <dd>{metric.value}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>

      <div class="metrics-shell">
        <PerformanceMetrics />
      </div>
    </section>

    <section class="closing-cta" data-phaeno-search-ignore>
      <div class="closing-cta__inner">
        <p>
          <span>Ready to resolve your samples</span>
          <span>down to the isoform?</span>
        </p>
        <div class="closing-cta__actions">
          <a class="closing-cta__primary" href="/contact#request-demo">Request a demo</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
.home-main {
  padding-top: 0;
}

.platform-section {
  padding-top: clamp(3rem, 5vw, 4.5rem);
}

.platform-intro {
  display: grid;
  grid-template-columns: minmax(0, 1.25fr) minmax(20rem, .75fr);
  gap: clamp(2rem, 5vw, 5rem);
  align-items: start;
}

.section-kicker {
  margin: 0 0 var(--space-3);
  padding: 0;
  color: var(--color-brand-strong);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  letter-spacing: .16em;
  text-transform: uppercase;
}

.platform-intro h2 {
  max-width: 20ch;
  margin: 0;
  padding: 0;
  font-size: clamp(2.35rem, 4vw, 3.75rem);
  line-height: .98;
}

.platform-copy {
  padding-top: var(--space-8);
}

.platform-copy p {
  margin: 0;
  padding: 0;
  font-size: var(--font-size-lg);
  line-height: var(--line-height-relaxed);
}

.platform-copy .platform-thesis {
  margin-top: var(--space-5);
  color: var(--phaeno-rna-900);
  font-weight: var(--font-weight-semibold);
}

.platform-links {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  margin-top: var(--space-6);
}

.platform-links a {
  display: inline-flex;
  align-items: center;
  gap: var(--space-3);
  padding: .7rem 1rem;
  border: 1px solid var(--phaeno-green-200);
  border-radius: var(--radius-pill);
  color: var(--color-brand-strong);
  background: var(--phaeno-green-50);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  transition:
    color var(--duration-fast) var(--ease-standard),
    background var(--duration-fast) var(--ease-standard),
    border-color var(--duration-fast) var(--ease-standard),
    transform var(--duration-fast) var(--ease-standard);
}

.platform-links a:hover {
  color: var(--color-text-on-dark);
  border-color: var(--color-brand-strong);
  background: var(--color-brand-strong);
  transform: translateY(-1px);
}

.platform-links a.platform-links__featured {
  color: var(--color-text-on-dark);
  border-color: var(--color-brand-strong);
  background: var(--color-brand-strong);
}

.platform-links a.platform-links__featured:hover {
  border-color: var(--phaeno-rna-900);
  background: var(--phaeno-rna-900);
}

.platform-links a span {
  transition: transform var(--duration-fast) var(--ease-standard);
}

.platform-links a:hover span {
  transform: translateX(2px);
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  grid-auto-rows: 1fr;
  gap: var(--space-4);
  margin-top: clamp(1.5rem, 2vw, 2.5rem);
}

.feature-card {
  height: 100%;
  min-height: 16rem;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding: var(--space-6) clamp(1.5rem, 3vw, 2.5rem);
  border: 1px solid var(--phaeno-green-200);
  border-radius: var(--radius-2xl);
  background: linear-gradient(155deg, var(--color-surface) 20%, var(--phaeno-green-50));
  box-shadow: var(--shadow-sm);
}

.feature-card:nth-child(n + 3) {
  justify-content: center;
}

.feature-card--lead {
  grid-column: auto;
  color: var(--color-text-on-dark);
  border-color: rgb(183 200 164 / .22);
  background:
    radial-gradient(circle at 80% 20%, rgb(28 127 152 / .3), transparent 40%),
    var(--phaeno-rna-900);
}

.feature-card__eyebrow {
  margin: 0;
  padding: 0;
  color: var(--color-brand-strong);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  letter-spacing: .13em;
  text-transform: uppercase;
}

.feature-card--lead .feature-card__eyebrow {
  color: var(--phaeno-green-300);
}

.feature-card h3 {
  max-width: 18ch;
  margin: var(--space-6) 0 0;
  padding: 0;
  font-size: clamp(1.45rem, 2.4vw, 2.25rem);
  line-height: 1.08;
}

#ml-ready-outputs {
  max-width: 100%;
}

.feature-card--lead h3 {
  color: var(--color-text-on-dark);
}

.feature-card__title-line {
  white-space: nowrap;
}

.feature-card > p:last-child {
  max-width: 38rem;
  margin: var(--space-4) 0 0;
  padding: 0;
  color: var(--color-text-muted);
  line-height: 1.55;
}

.feature-card--lead > p:last-child {
  color: rgb(255 255 255 / .7);
}

.platform-cta {
  width: 100vw;
  margin-inline: calc(50% - 50vw);
  margin-top: var(--space-4);
  color: var(--color-text-on-dark);
  background:
    radial-gradient(circle at 78% 18%, rgb(28 127 152 / .28), transparent 38%),
    var(--phaeno-rna-900);
}

.platform-cta__inner {
  width: 100%;
  max-width: var(--content-max-width);
  margin: 0 auto;
  padding: clamp(3rem, 6vw, 5rem) var(--page-gutter);
}

.platform-cta__content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-8);
}

.platform-cta .section-kicker {
  color: var(--phaeno-green-300);
}

.platform-cta__content p {
  max-width: 42rem;
  margin: 0;
  padding: 0;
}

.platform-cta__content > div > p:last-child {
  color: rgb(255 255 255 / .76);
  font-size: var(--font-size-lg);
  line-height: var(--line-height-relaxed);
}

.platform-cta__content > a {
  flex: 0 0 auto;
  display: inline-flex;
  gap: var(--space-3);
  padding: .8rem 1.1rem;
  color: var(--color-text-on-dark);
  background: var(--phaeno-orange-500);
  border-radius: var(--radius-pill);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  transition:
    background-color var(--duration-base) var(--ease-standard),
    box-shadow var(--duration-base) var(--ease-standard),
    transform var(--duration-fast) var(--ease-standard);
}

.platform-cta__content > a:hover {
  color: var(--color-text-on-dark);
  background: var(--phaeno-orange-600);
  box-shadow: var(--shadow-md);
  transform: translateY(-1px);
}

.platform-cta__content > a span {
  transition: transform var(--duration-fast) var(--ease-standard);
}

.platform-cta__content > a:hover span {
  transform: translateX(2px);
}

.platform-metrics {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  margin: clamp(2.5rem, 5vw, 4rem) 0 0;
  padding: clamp(1.75rem, 3vw, 2.5rem) 0 0;
  border-top: 1px solid rgb(255 255 255 / .2);
}

.platform-metric {
  display: flex;
  min-width: 0;
  flex-direction: column;
  padding: 0 clamp(1rem, 2.5vw, 2rem);
  border-left: 1px solid rgb(255 255 255 / .16);
}

.platform-metric:first-child {
  padding-left: 0;
  border-left: 0;
}

.platform-metric:last-child {
  padding-right: 0;
}

.platform-metric dt {
  margin: var(--space-2) 0 0;
  color: rgb(255 255 255 / .72);
  font-size: var(--font-size-sm);
  line-height: var(--line-height-copy);
}

.platform-metric dt span {
  display: block;
}

.platform-metric dd {
  order: -1;
  margin: 0;
  color: var(--color-text-on-dark);
  font-size: clamp(1.75rem, 3vw, 2.4rem);
  font-weight: var(--font-weight-semibold);
  line-height: var(--line-height-tight);
}

.metrics-shell {
  margin-top: clamp(2.5rem, 4vw, 4rem);
}

.closing-cta {
  max-width: none;
  padding: 0;
  background: var(--color-surface-rna);
}

.closing-cta__inner {
  width: 100%;
  max-width: var(--content-max-width);
  min-height: 13.5rem;
  margin: 0 auto;
  padding: clamp(3rem, 6vw, 5rem) var(--page-gutter);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-8);
}

.closing-cta p {
  max-width: 32rem;
  margin: 0;
  padding: 0;
  color: var(--color-text-on-dark);
  font-size: clamp(1.5rem, 2.1vw, 1.9rem);
  font-weight: var(--font-weight-semibold);
  line-height: 1.18;
}

.closing-cta p span {
  display: block;
}

.closing-cta__actions {
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

.closing-cta__actions a {
  min-width: 9.5rem;
  padding: .9rem 1.4rem;
  border: 1px solid transparent;
  border-radius: var(--radius-pill);
  color: var(--color-text-on-dark);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  text-align: center;
  transition:
    background-color var(--duration-base) var(--ease-standard),
    box-shadow var(--duration-base) var(--ease-standard),
    transform var(--duration-fast) var(--ease-standard);
}

.closing-cta__primary {
  background: var(--phaeno-orange-500);
}

.closing-cta__primary:hover {
  color: var(--color-text-on-dark);
  background: var(--phaeno-orange-600);
  box-shadow: var(--shadow-md);
  transform: translateY(-1px);
}

@media (max-width: 900px) {
  .platform-intro {
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .platform-copy {
    padding-top: 0;
  }

  .feature-grid {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 640px) {
  .feature-grid {
    grid-template-columns: 1fr;
  }

  .feature-card--lead {
    grid-column: auto;
  }

  .feature-card {
    min-height: 17rem;
  }

  .feature-card:nth-child(n + 3) {
    justify-content: flex-start;
  }

  .platform-cta__content {
    align-items: stretch;
    flex-direction: column;
  }

  .platform-cta__content > a {
    justify-content: center;
  }

  .platform-metrics {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    row-gap: var(--space-6);
  }

  .platform-metric {
    padding-inline: var(--space-4);
  }

  .platform-metric:nth-child(odd) {
    padding-left: 0;
    border-left: 0;
  }

  .platform-metric:nth-child(even) {
    padding-right: 0;
  }

  .platform-metric:nth-child(n + 3) {
    padding-top: var(--space-6);
    border-top: 1px solid rgb(255 255 255 / .16);
  }

  .closing-cta__inner {
    align-items: flex-start;
    flex-direction: column;
  }

  .closing-cta__actions {
    width: 100%;
    align-items: stretch;
    flex-direction: column;
  }
}
</style>
