---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import ShareWithSocialMedia from '@/components/ShareWithSocialMedia.astro';
import ArticleSEOMeta from '@/components/meta-data-helpers/ArticleSEOMeta.astro';
import { formatContentDate } from '@/lib/dates';


export async function getStaticPaths() {
  const papers = await getCollection('white_papers');
  return papers.map((paper) => ({
    params: { slug: paper.id },
    props: { paper },
  }));
}

const { paper } = Astro.props as { paper: CollectionEntry<'white_papers'> };
const { title, authors, date, summary, image } = paper.data;
const { Content } = await render(paper);
---

<title>White Papers | Phaeno</title>
<meta name="description" content="Phaeno is revolutionizing RNA sequencing with full-length, high-fidelity reads. Discover our platform and team." />

<Layout>
  <ArticleSEOMeta 
    slot="head"
    title={title}
    description={summary}
    datePosted={date}
    authors={authors}
    image={image}
    documentType="Web Page"
    searchTitle={`White Paper - ${title}`}
  />     
  <main id="main">
    <section>
      <p>Media | <a href="/media/white-papers">White Papers</a> | {paper.id}</p>
      <h1 id={`${title.replace(/\s+/g, '-').toLowerCase()}`} class="text-3xl sm:text-4xl font-semibold tracking-tight text-neutral-900">{title}</h1>
      <p class="text-sm text-gray-600">{authors.join(', ')}</p>
      <p class="text-sm text-gray-500">Published {formatContentDate(paper.data.date)}</p>
      <article>
        <Content />
      </article>

      <hr class="text-zinc-200 mt-12" />

      <div class="flex justify-end my-10">
        <ShareWithSocialMedia 
          title={title} 
          link={Astro.url.pathname}
          summary={summary} 
        />
      </div>        
    </section>
  </main>
</Layout>
