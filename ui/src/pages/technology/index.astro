---
import Layout from '@/layouts/Layout.astro';
import TopPageBanner from '@/components/TopPageBanner.astro';
import SEOMeta from '@/components/meta-data-helpers/SEOMeta.astro';
import NewSeqCategory from '@/components/NewSeqCategory.astro';
---
<Layout>
  <SEOMeta 
    slot="head"
    title="Technology | Phaeno"
    description="Explore Phaeno’s technology and how integrated chemistry and software enable full-length, isoform-resolved transcriptome sequencing."
    documentType="Web Page"
    searchTitle="Technology"
    searchKeywords="PSeq technology phased sequencing chemistry single-molecule tagging molecular barcodes intramolecular library construction isothermal amplification UMI redistribution automated pipeline NGS instruments"
  />  
  <main id="main" class="science-page" tabindex="-1">
    <TopPageBanner title="PSeq Technology" image="image-2" trademark />
    <section>
      <h2
        id="pseq-technology"
        data-phaeno-search="PSeq sequencing technology category"
        data-phaeno-search-summary="Visual overview of PSeq as a phased sequencing category that adds molecule-level isoform resolution to established NGS workflows."
        data-phaeno-search-keywords="PSeq phased sequencing NGS molecular identity molecule-level isoform resolution transcript reconstruction software"
      >PSeq — A New Category Built Around Resolution</h2>
      <div class="category-context">
        <p>
          Sequencing advanced through foundation, scale, and read length. PSeq adds molecule-level isoform resolution.
          By preserving molecular identity through an NGS workflow, it allows reads from the same captured template to
          be grouped before transcript reconstruction.
        </p>
        <p class="category-context__claim">
          <strong>Not another sequencer.</strong>
          <span>A new architecture for molecule-resolved RNA measurement.</span>
        </p>
      </div>
      <div class="category-timeline-wrap">
        <div class="category-timeline-inner">
          <NewSeqCategory />
        </div>
      </div>
      <h2
        id="new-insights-in-chemistry"
        data-phaeno-search="How PSeq technology works"
        data-phaeno-search-summary="PSeq uses single-molecule tagging, intramolecular library construction, and automated data processing to produce full-length RNA insight."
        data-phaeno-search-keywords="PSeq technology single-molecule tagging intramolecular library construction automated data processing"
      >How PSeq Technology Works</h2>
      <p class="mechanism-intro">
        Three connected stages transform individual RNA molecules into complete, analysis-ready sequence data.
      </p>
      <div class="mechanism-flow">
        <article class="mechanism-card mechanism-card--featured" data-motion-reveal data-motion-delay="0">
          <div class="mechanism-card__step">
            <span>01</span>
            <span>Identify</span>
          </div>
          <h3>Tag every molecule</h3>
          <p>
            Each RNA molecule is reverse-transcribed using one of 4.3 trillion multifunctional tagging reagents,
            uniquely labeling individual molecules.
          </p>
          <div class="mechanism-card__result">4.3 trillion-tag molecular identity space</div>
        </article>

        <article class="mechanism-card" data-motion-reveal data-motion-delay="50">
          <div class="mechanism-card__step">
            <span>02</span>
            <span>Construct</span>
          </div>
          <h3>Build within each molecule</h3>
          <p>
            Tagged molecules are converted into sequencing-ready DNA libraries using reactions confined to
            intramolecular rearrangements.
          </p>
          <div class="mechanism-card__result">Sequencing-ready DNA libraries</div>
        </article>

        <article class="mechanism-card" data-motion-reveal data-motion-delay="100">
          <div class="mechanism-card__step">
            <span>03</span>
            <span>Resolve</span>
          </div>
          <h3>Process data end to end</h3>
          <p>
            Standard FASTA files from the sequencer are processed end-to-end by the automated PSeq data pipeline.
          </p>
          <div class="mechanism-card__result">Complete, analysis-ready output</div>
        </article>
      </div>
      <aside class="ngs-compatibility" aria-label="PSeq NGS compatibility">
        <div class="ngs-compatibility__inner">
          <div class="ngs-compatibility__message">
            <span class="ngs-compatibility__eyebrow">Built for the lab you already run</span>
            <h3>Standard NGS in. Isoform-resolved data out.</h3>
          </div>
          <div class="ngs-compatibility__details">
            <p>
              PSeq runs on unmodified NGS sequencers already in service—without specialized Third Generation instruments,
              dedicated robotics, or highly specialized staff training.
            </p>
            <ul aria-label="PSeq compatibility benefits">
              <li>Existing NGS instruments</li>
              <li>No dedicated robotics</li>
              <li>Automated FASTA processing</li>
            </ul>
            <a href="/contact#sign-up" class="ngs-compatibility__cta">
              Request Technical Brief <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </aside>
      <h2
        id="pseq-workflow"
        data-phaeno-search="From sample to isoform-resolved PSeq data"
        data-phaeno-search-summary="Detailed PSeq stages covering molecular tagging, molecule-aware processing, molecule-constrained reconstruction, and ML-ready isoform-level output."
        data-phaeno-search-keywords="PSeq workflow molecular tagging isothermal amplification UMI redistribution molecule-aware processing quality control molecular assignment transcript reconstruction ML-ready isoform output"
      >From Sample to Isoform-Resolved Data</h2>
      <p class="workflow-detail-intro">
        PSeq moves from molecular preparation through automated processing to structured, molecule-level output—within
        the NGS workflow already in use.
      </p>
      <div class="workflow-detail-grid">
        <article class="work-flow-description workflow-card--apply">
          <header class="workflow-card__header">
            <span class="workflow-card__stage">Apply</span>
            <h3>PSeq Chemistry</h3>
            <p>Four molecular preparation steps preserve the identity and structure of each RNA molecule.</p>
          </header>
          <ol class="workflow-card__list workflow-card__list--numbered">
            <li>
              <span class="workflow-card__marker" aria-hidden="true">01</span>
              <div><strong>Molecular tagging</strong><span>Reverse transcription with individual barcodes and strand discriminators.</span></div>
            </li>
            <li>
              <span class="workflow-card__marker" aria-hidden="true">02</span>
              <div><strong>Isothermal amplification</strong><span>PCR-free amplification.</span></div>
            </li>
            <li>
              <span class="workflow-card__marker" aria-hidden="true">03</span>
              <div><strong>Intermolecular UMI redistribution</strong><span>SMIDs are relocated to the start of Read 1 in standard paired-end NGS libraries.</span></div>
            </li>
            <li>
              <span class="workflow-card__marker" aria-hidden="true">04</span>
              <div><strong>Companion tools</strong><span>Retrieve individual, barcode-identified molecules discovered by sequencing.</span></div>
            </li>
          </ol>
        </article>
        <article class="work-flow-description workflow-card--execute">
          <header class="workflow-card__header">
            <span class="workflow-card__stage">Execute</span>
            <h3>PSeq Software</h3>
            <p>
              An automated, molecule-aware pipeline carries sequencing data through preprocessing, quality control,
              molecular assignment, transcript reconstruction, and structured output.
            </p>
          </header>
          <ul class="workflow-card__list">
            <li>
              <div>
                <strong>Molecule-aware processing</strong>
                <span>Preprocessing and quality control prepare reads for molecule-specific assignment, which is evaluated before transcript assembly.</span>
              </div>
            </li>
            <li>
              <div>
                <strong>Molecule-constrained reconstruction</strong>
                <span>With sufficient depth and coverage, reads assigned to each captured molecular template support a more direct view of individual isoforms than inference from pooled fragments.</span>
              </div>
            </li>
            <li>
              <div>
                <strong>Interoperable outputs</strong>
                <span>Structured isoform-level results can connect with biological databases and established bioinformatics, visualization, ML, and AI tools.</span>
              </div>
            </li>
          </ul>
        </article>
        <article class="work-flow-description workflow-card--deliver">
          <header class="workflow-card__header">
            <span class="workflow-card__stage">Deliver</span>
            <h3><span class="workflow-title__nowrap">Isoform&#8209;Resolved</span> Insights</h3>
            <p>Individual-molecule data, structured for analysis and discovery.</p>
          </header>
          <ul class="workflow-card__list">
            <li>
              <div><strong>Isoform architecture</strong><span>Connected exon and UTR structure within individual RNA molecules.</span></div>
            </li>
            <li>
              <div><strong>Protein-coding potential</strong><span>Open reading frames and alternative initiation sites.</span></div>
            </li>
            <li>
              <div><strong>Polyadenylation</strong><span>Alternative cleavage and polyadenylation sites.</span></div>
            </li>
            <li>
              <div><strong>ML-ready outputs</strong><span>Structured, molecule-level features designed as inputs to downstream ML models.</span></div>
            </li>
          </ul>
        </article>
      </div>
      <aside
        class="technical-discussion"
        aria-labelledby="technical-discussion-title"
        data-phaeno-search-ignore
      >
        <div class="technical-discussion__copy">
          <p class="technical-discussion__eyebrow">Apply PSeq to your work</p>
          <h2 id="technical-discussion-title">Ready to explore PSeq for your workflow?</h2>
          <p>Discuss your samples, sequencing setup, and research goals with our team.</p>
        </div>
        <a class="technical-discussion__cta" href="/contact#request-demo">
          Request a technical discussion <span aria-hidden="true">→</span>
        </a>
      </aside>
    </section>
  </main>
</Layout>

<style lang="scss">
.science-page {
  container-type: inline-size;
}

.category-context {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(18rem, .65fr);
  gap: clamp(2rem, 5vw, 5rem);
  align-items: start;
  margin: var(--space-3) 0 var(--space-6);
}

.category-context > p {
  margin: 0;
  color: var(--color-text-muted);
  font-size: var(--font-size-lg);
  line-height: 1.65;
}

.category-context__claim {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  padding-left: var(--space-5);
  border-left: 3px solid var(--color-brand);
}

.category-context__claim strong {
  color: var(--phaeno-rna-900);
  font-size: var(--font-size-xl);
  line-height: 1.2;
}

.category-context__claim span {
  font-size: var(--font-size-md);
}

.category-timeline-wrap {
  width: 100cqw;
  margin-inline: calc(50% - 50cqw);
  margin-bottom: var(--space-8);
  padding: clamp(2rem, 4vw, 3rem) 0;
  background: var(--phaeno-green-50);
}

.category-timeline-inner {
  width: 100%;
  max-width: var(--content-max-width);
  margin: 0 auto;
  padding: 0 var(--page-gutter);
}

.category-timeline-inner :global(.sequencing-timeline) {
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
}

#new-insights-in-chemistry,
#pseq-workflow {
  margin-top: clamp(2rem, 4vw, 3rem);
}

.mechanism-intro {
  max-width: 48rem;
  margin: var(--space-3) 0 var(--space-7);
  color: var(--color-text-muted);
  font-size: var(--font-size-lg);
}

.mechanism-flow {
  position: relative;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: var(--space-4);
}

.mechanism-flow::before {
  content: '';
  position: absolute;
  top: 3.15rem;
  left: 8%;
  right: 8%;
  height: 1px;
  background: var(--phaeno-green-200);
}

.mechanism-card {
  position: relative;
  z-index: 1;
  display: flex;
  min-height: 20rem;
  flex-direction: column;
  padding: clamp(1.5rem, 2.5vw, 2.25rem);
  border: 1px solid var(--phaeno-green-200);
  border-radius: var(--radius-xl);
  background: var(--phaeno-neutral-50);
  box-shadow: var(--shadow-sm);
}

.mechanism-card--featured {
  color: var(--color-text-on-dark);
  border-color: var(--phaeno-rna-800);
  background: var(--phaeno-rna-900);
}

.mechanism-card__step {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  color: var(--color-brand-strong);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  letter-spacing: .14em;
  text-transform: uppercase;
}

.mechanism-card__step span:first-child {
  display: grid;
  width: 2.75rem;
  height: 2.75rem;
  place-items: center;
  border: 1px solid currentColor;
  border-radius: 50%;
  background: var(--color-surface);
}

.mechanism-card--featured .mechanism-card__step {
  color: var(--phaeno-green-200);
}

.mechanism-card--featured .mechanism-card__step span:first-child {
  background: var(--phaeno-rna-900);
}

.mechanism-card h3 {
  margin: var(--space-7) 0 var(--space-4);
  font-size: clamp(1.55rem, 2.25vw, 2rem);
  line-height: 1.08;
}

.mechanism-card--featured h3 {
  color: var(--color-text-on-dark);
}

.mechanism-card p {
  margin: 0;
  color: var(--color-text-muted);
  line-height: 1.65;
}

.mechanism-card--featured p {
  color: var(--phaeno-neutral-200);
}

.mechanism-card__result {
  margin-top: auto;
  padding-top: var(--space-6);
  color: var(--color-brand-strong);
  font-family: var(--font-family-mono);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  letter-spacing: .04em;
  text-transform: uppercase;
}

.mechanism-card--featured .mechanism-card__result {
  color: var(--phaeno-green-200);
}

.ngs-compatibility {
  position: relative;
  overflow: hidden;
  width: 100cqw;
  margin-inline: calc(50% - 50cqw);
  margin-top: clamp(2rem, 4vw, 3rem);
  color: var(--color-text-on-dark);
  background:
    radial-gradient(circle at 100% 0%, rgb(28 127 152 / 28%), transparent 36%),
    var(--phaeno-rna-900);
}

.ngs-compatibility__inner {
  display: grid;
  grid-template-columns: minmax(18rem, .8fr) minmax(24rem, 1.2fr);
  gap: clamp(2rem, 5vw, 5rem);
  align-items: start;
  width: 100%;
  max-width: var(--content-max-width);
  margin: 0 auto;
  padding: clamp(3rem, 6vw, 5rem) var(--page-gutter);
}

.ngs-compatibility::after {
  content: '';
  position: absolute;
  right: -4rem;
  bottom: -6rem;
  width: 15rem;
  height: 15rem;
  border: 1px solid rgb(214 227 195 / 24%);
  border-radius: 50%;
}

.ngs-compatibility__eyebrow {
  color: var(--phaeno-green-200);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  letter-spacing: .14em;
  text-transform: uppercase;
}

.ngs-compatibility h3 {
  margin: var(--space-2) 0 0;
  color: var(--color-text-on-dark);
  font-size: clamp(1.4rem, 2.25vw, 1.85rem);
  line-height: 1.15;
}

.ngs-compatibility p {
  margin: 0;
  color: var(--phaeno-neutral-200);
  line-height: 1.65;
}

.ngs-compatibility__details {
  position: relative;
  z-index: 1;
}

.ngs-compatibility ul {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin: var(--space-5) 0 var(--space-6);
  padding: 0;
  list-style: none;
}

.ngs-compatibility li {
  display: inline-flex;
  width: auto !important;
  align-items: center;
  gap: var(--space-2);
  padding: .45rem .75rem;
  border: 1px solid rgb(214 227 195 / 32%);
  border-radius: var(--radius-pill);
  color: var(--phaeno-green-200);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  letter-spacing: .03em;
}

.ngs-compatibility li::before {
  content: '';
  width: .4rem;
  height: .4rem;
  flex: 0 0 auto;
  border-radius: 50%;
  background: var(--phaeno-green-300);
}

.ngs-compatibility__cta {
  display: inline-flex;
  align-items: center;
  gap: var(--space-3);
  padding: .8rem 1.15rem;
  border-radius: var(--radius-pill);
  color: var(--color-text-on-dark);
  background: var(--phaeno-orange-500);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  box-shadow: var(--shadow-sm);
  transition:
    background var(--duration-fast) var(--ease-standard),
    transform var(--duration-fast) var(--ease-standard);
}

.ngs-compatibility__cta:hover {
  color: var(--color-text-on-dark);
  background: var(--phaeno-orange-600);
  transform: translateY(-1px);
}

.ngs-compatibility__cta span {
  transition: transform var(--duration-fast) var(--ease-standard);
}

.ngs-compatibility__cta:hover span {
  transform: translateX(2px);
}

.work-flow-description {
  overflow: hidden;
  display: grid;
  grid-template-columns: minmax(18rem, .85fr) minmax(0, 1.8fr);
  border: 1px solid var(--phaeno-green-200);
  border-radius: var(--radius-xl);
  background: var(--color-surface);
  box-shadow: var(--shadow-sm);
}

.workflow-detail-intro {
  max-width: 52rem;
  margin: var(--space-3) 0 var(--space-6);
  color: var(--color-text-muted);
  font-size: var(--font-size-lg);
  line-height: 1.65;
}

.workflow-detail-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-4);
}

.technical-discussion {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: clamp(2rem, 5vw, 4rem);
  margin-top: clamp(2rem, 4vw, 3rem);
  padding: clamp(2rem, 4vw, 3rem);
  border: 1px solid var(--phaeno-green-200);
  border-radius: var(--radius-xl);
  background: var(--phaeno-green-50);
}

.technical-discussion__copy {
  max-width: 42rem;
}

.technical-discussion__eyebrow {
  margin: 0 0 var(--space-3);
  color: var(--color-brand-strong);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  letter-spacing: .14em;
  text-transform: uppercase;
}

.technical-discussion h2 {
  margin: 0;
  color: var(--phaeno-rna-900);
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  line-height: 1.08;
}

.technical-discussion__copy > p:last-child {
  margin: var(--space-3) 0 0;
  color: var(--color-text-muted);
  font-size: var(--font-size-lg);
  line-height: 1.55;
}

.technical-discussion__cta {
  display: inline-flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  gap: var(--space-3);
  padding: .9rem 1.35rem;
  border-radius: var(--radius-pill);
  color: var(--color-text-on-dark);
  background: var(--phaeno-orange-500);
  font-weight: var(--font-weight-semibold);
  text-align: center;
  transition:
    color var(--duration-fast) var(--ease-standard),
    background-color var(--duration-base) var(--ease-standard),
    box-shadow var(--duration-base) var(--ease-standard),
    transform var(--duration-fast) var(--ease-standard);
}

.technical-discussion__cta:hover {
  color: var(--color-text-on-dark);
  background: var(--phaeno-orange-600);
  box-shadow: var(--shadow-md);
  transform: translateY(-1px);
}

.technical-discussion__cta span {
  transition: transform var(--duration-fast) var(--ease-standard);
}

.technical-discussion__cta:hover span {
  transform: translateX(2px);
}

.workflow-card__header {
  padding: clamp(1.5rem, 2.5vw, 2rem);
  border-right: 1px solid var(--color-border);
  background: var(--phaeno-green-50);
}

.workflow-card__stage {
  display: inline-flex;
  align-items: center;
  padding: .4rem .7rem;
  border: 1px solid var(--phaeno-green-200);
  border-radius: var(--radius-pill);
  color: var(--color-brand-strong);
  background: var(--phaeno-green-100);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  letter-spacing: .12em;
  text-transform: uppercase;
}

.workflow-card__header h3 {
  margin: var(--space-6) 0 var(--space-3);
  color: var(--phaeno-rna-900);
  font-size: clamp(1.6rem, 2.4vw, 2.1rem);
  line-height: 1.08;
}

.workflow-title__nowrap {
  white-space: nowrap;
}

.workflow-card__header p {
  margin: 0;
  color: var(--color-text-muted);
  line-height: 1.55;
}

.workflow-card__list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  align-content: stretch;
  gap: var(--space-3);
  list-style: none;
  margin: 0;
  padding: clamp(1.25rem, 2vw, 1.75rem);
  background: var(--color-surface);
}

.workflow-card__list li {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  min-height: 0;
  height: 100%;
  padding: var(--space-4);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  background: var(--phaeno-neutral-50);
}

.workflow-card__marker {
  display: grid;
  width: 2rem;
  height: 2rem;
  flex: 0 0 2rem;
  place-items: center;
  border: 1px solid var(--phaeno-green-200);
  border-radius: 50%;
  color: var(--color-brand-strong);
  background: var(--phaeno-green-50);
  font-family: var(--font-family-data);
  font-size: .68rem;
  font-weight: var(--font-weight-bold);
}

.workflow-card__list li > div {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.workflow-card__list:not(.workflow-card__list--numbered) li > div {
  width: 100%;
}

.workflow-card__list:not(.workflow-card__list--numbered) li {
  align-items: flex-start;
  flex-direction: column;
  justify-content: flex-start;
  gap: var(--space-3);
}

.workflow-card__list:not(.workflow-card__list--numbered) li::before {
  width: 2rem;
  height: 2px;
  flex: 0 0 auto;
  border-radius: var(--radius-pill);
  background: var(--color-brand-strong);
  content: '';
}

.workflow-card__list strong {
  color: var(--phaeno-rna-900);
  font-size: var(--font-size-sm);
  line-height: 1.3;
}

.workflow-card__list li > div > span {
  color: var(--color-text-muted);
  font-size: var(--font-size-sm);
  line-height: 1.45;
}

.workflow-card--execute .workflow-card__header {
  color: var(--color-text-on-dark);
  border-color: rgb(255 255 255 / 14%);
  background:
    radial-gradient(circle at 100% 0%, rgb(28 127 152 / 30%), transparent 46%),
    var(--phaeno-rna-900);
}

.workflow-card--execute .workflow-card__stage {
  border-color: rgb(255 255 255 / 24%);
  color: var(--phaeno-green-100);
  background: rgb(255 255 255 / 14%);
}

.workflow-card--execute .workflow-card__header h3 {
  color: var(--color-text-on-dark);
}

.workflow-card--execute .workflow-card__header p {
  color: var(--phaeno-neutral-200);
