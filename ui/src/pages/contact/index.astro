---
import Layout from '@/layouts/Layout.astro';
import SEOMeta from '@/components/meta-data-helpers/SEOMeta.astro';
import ContactUsForms from '@/components/contact-forms/ContactUsForms';
import TopPageBanner from '@/components/TopPageBanner.astro';
import SocialMedia from '@/components/SocialMedia.astro';
import ReCaptchaNotification from '@/components/ReCaptchaNotification.astro';
//import ScheduleMeeting from '@/components/ScheduleMeeting.astro';
---
<Layout>
  <SEOMeta 
    slot="head"
    title="Contact Us | Phaeno"
    description="Contact Phaeno to discuss PSeq RNA sequencing technology, partnerships, investor inquiries, or company updates."
    documentType="Web Page"
    searchTitle="Contact"
    searchKeywords="contact Phaeno PSeq demo request technical brief partnerships investor inquiries company updates Irvine RNA sequencing"
  />  
  <main id="main" class="contact-page" tabindex="-1">
    <TopPageBanner title="Contact Us" image="image-2"/>
    <section>
      <h2
        id="contact-details"
        data-phaeno-search="Phaeno contact details"
        data-phaeno-search-summary="Contact Phaeno in Irvine, California for PSeq demos, technical briefs, partnerships, investor inquiries, and company updates."
        data-phaeno-search-keywords="Phaeno contact Irvine PSeq demo technical brief partnerships investors"
      >Contact Details</h2>
      <div class="contact-details-container">
        <div class="flex flex-col gap-1.5">
          <h3 class="p-0 text-[1.1rem]">Street Address</h3>
          <div class="text-black text-sm">5270 California Avenue<br />Suite 300<br />Irvine, CA 92617</div>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="p-0 text-[1.1rem]">Get in Touch</h3>
          <!-- <div class="text-sm"><a href="tel:+1-###-###-####">+1-###-###-####</a></div>
          <div class="text-sm"><a href="mailto:sales@phaenobiotech.com">info@phaenobiotech.com</a></div> -->
          <div class="text-sm"><a href="mailto:info@phaenobiotech.com">info@phaenobiotech.com</a></div>
          <!-- <ScheduleMeeting /> -->
        </div>
        <div class="flex flex-col social-media">
          <h3 class="p-0 text-[1.1rem] mb-1">Stay In Touch</h3>
          <SocialMedia size="lg" />
        </div>
      </div>
      <ContactUsForms client:load />
      <ReCaptchaNotification />
    </section>
  </main>
</Layout>

<style>
.contact-details-container {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  justify-items: start;
  gap: var(--space-4);
  margin-top: var(--space-5);
}

.contact-details-container > div {
  flex: 1;
  min-height: 7.5rem;
  padding: var(--space-4) var(--space-8);
  border: 1px solid var(--phaeno-green-200);
  border-radius: var(--radius-xl);
  background: var(--phaeno-green-50);
}

:global(.demo-band) {
  width: 100vw;
  max-width: none;
  margin: clamp(3rem, 5vw, 4.5rem) calc(50% - 50vw);
  padding: 0;
  background:
    radial-gradient(circle at 88% 16%, rgb(214 227 195 / .72), transparent 32%),
    var(--phaeno-green-100);
}

:global(.demo-band__inner) {
  width: 100%;
  max-width: var(--content-max-width);
  margin: 0 auto;
  padding: clamp(3rem, 6vw, 5rem) var(--page-gutter);
}

:global(.demo-band__inner > h2) {
  margin-top: 0;
}

:global(.demo-band__inner > p) {
  margin-top: 0;
  color: var(--color-text-muted);
  font-size: var(--font-size-lg);
}

.social-media {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

@media (max-width: 725px) {
	.contact-details-container {
    flex-direction: column;
    gap: 2rem;
	}

  .social-media {
    display: block;
  }
}
</style>
