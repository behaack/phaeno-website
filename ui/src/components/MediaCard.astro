---
import { Image } from 'astro:assets';
import { FaArrowRight } from 'react-icons/fa6';

interface IProps {
  title: string
  image?: string
  summary?: string
  link: string
  searchString: string
}
const { title, image="", link, searchString, summary } = Astro.props as IProps
---

<li 
  class="media-card-item"
  data-search={searchString} 
>
  <a class="media-card-link" href={link} aria-label={title}>
    <div class="photo-frame">
      <Image
        src={image}
        alt=""
        height={360}
        width={640}
      />
    </div>
    <div class="text-frame">
      <div class="title-frame">
        <h2>{title}</h2>
      </div>
      <div class="summary-frame">
        {summary}
      </div>
      <div class="details-frame">
        <slot />
      </div>
      <span class="card-arrow" aria-hidden="true">
        <FaArrowRight size={20} />
      </span>
    </div>
  </a>
</li>

<style>
.media-card-item {
  border-radius: var(--radius-xl);
  background: var(--color-surface);
  border: 1px solid var(--phaeno-green-200);
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  height: 100%;
  width: 100%;
  overflow: hidden;
  transition: transform var(--duration-base) var(--ease-standard), box-shadow var(--duration-base) var(--ease-standard);
}

.media-card-item:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.media-card-item:focus-within {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.media-card-link {
  color: inherit;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  height: 100%;
  text-decoration: none;
  width: 100%;
}

.media-card-link:focus-visible {
  outline-offset: -3px;
}

.photo-frame {
  aspect-ratio: 16 / 9;
  background: var(--phaeno-green-50);
  overflow: hidden;
}

.photo-frame img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;  
}

.text-frame {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: var(--space-3);
  padding: var(--space-5);
  position: relative;
}

.title-frame {
  overflow: hidden;
}

.summary-frame {
  color: var(--color-text-muted);
  font-size: var(--font-size-sm);
  line-height: 1.5;
}

.details-frame {
  color: black;
  font-size: .8rem;
  line-height: 1.3;
  margin-top: auto;
  max-width: 100%;
  padding-right: calc(1.25rem + var(--space-3));
}

.card-arrow {
  color: var(--color-action-primary);
  display: flex;
  justify-content: flex-end;
  position: absolute;
  right: var(--space-5);
  bottom: var(--space-5);
  transition: transform var(--duration-base) var(--ease-standard);
}

.media-card-link:hover .card-arrow,
.media-card-link:focus-visible .card-arrow {
  transform: translateX(3px);
}

h2 {
  color: var(--phaeno-rna-900);
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
  line-height: 1.2;
  padding: 0 0 5px 0;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}
</style>
