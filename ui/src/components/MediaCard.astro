---
import { Image } from 'astro:assets';
import { FaArrowRight } from 'react-icons/fa6';

interface IProps {
  title: string
  image?: string
  link: string
  searchString: string
}
const { title, image="", link, searchString } = Astro.props as IProps
---

<li 
  class="media-card-item"
  data-search={searchString} 
>
  <div class="photo-frame">
    <Image
      src={image}
      alt={`Photo ${title}`} 
      height={360}
      width={640}
    />
  </div>
  <div class="text-frame">
    <div class="title-frame">
      <h2>{title}</h2>
    </div>    
    <div class="details-frame">
      <slot />
    </div>
    <div class="text-right">
      <a class="btn" href={link}>
        <FaArrowRight size={20} />
      </a>
    </div>
  </div>
</li>

<style>
.media-card-item {
  border-radius: 0.5rem;
  background: #eeeee8c5;
  border: 1px solid rgba(0,0,0,0.06);
  box-shadow: 0 8px 20px rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  height: 100%;
  width: 100%;
  overflow: hidden;
}

.photo-frame {
  aspect-ratio: 16 / 9;
  background: #f5f6f2;
  overflow: hidden;
}

.photo-frame img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;  
}

.text-frame {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 0.75rem;
  padding: 1rem;
}

.title-frame {
  overflow: hidden;
}

.details-frame {
  color: black;
  font-size: .8rem;
  line-height: 1.3;
  max-width: 100%;
}

.text-right {
  display: flex;
  justify-content: flex-end;
  margin-top: auto;
}

.btn {
  align-items: center;
  text-align: center;
  display: inline-flex;
  justify-content: center;
  background-color: #545458;
  color: white;
  font-weight: 600;
  padding: 10px;
  border-radius: 100px;
  text-decoration: none;
  transition: color 0.3s ease, transform 0.3s ease;
}

.btn:hover {
  background-color: black;
  cursor: pointer;
  transform: scale(1.05);
}

h2 {
  font-size: 1.05rem;
  font-weight: 600;
  line-height: 1.2;
  padding: 0 0 5px 0;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}
</style>
