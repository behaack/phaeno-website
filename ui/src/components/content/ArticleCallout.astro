---
interface Props {
  align?: 'left' | 'center';
}

const { align = 'left' } = Astro.props;
---

<aside class={`article-callout article-callout-${align}`}>
  <div class="article-callout__content">
    <slot />
  </div>
</aside>

<style>
.article-callout {
  margin: 1rem 0 1.25rem;
  padding: 0.8rem 1rem;
  border-left: 4px solid var(--color-brand);
  background: var(--phaeno-green-50);
  color: var(--color-text);
  line-height: 1.5;
}

.article-callout-center {
  display: grid;
  grid-template-columns: minmax(1.5rem, 1fr) minmax(0, auto) minmax(1.5rem, 1fr);
  gap: clamp(0.75rem, 2vw, 1.5rem);
  align-items: center;
  margin: 0 0 clamp(2.5rem, 5vw, 3.5rem);
  padding: 0;
  border-left: 0;
  background: transparent;
  color: var(--phaeno-rna-900);
  font-size: var(--font-size-md);
  font-style: italic;
  letter-spacing: 0.01em;
  text-align: center;
}

.article-callout-center::before,
.article-callout-center::after {
  height: 1px;
  background: var(--phaeno-green-300);
  content: '';
}

.article-callout-center .article-callout__content {
  max-width: 32rem;
}

.article-callout :global(p) {
  margin: 0;
  padding: 0;
}
</style>
