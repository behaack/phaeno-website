---
interface ComparisonRow {
  characteristic: string;
  rnaSeq: string;
  longReadSeq: string;
  pseq: string;
  highlighted?: boolean;
}

type ComparisonColumn = 'characteristic' | 'pseq' | 'rnaSeq' | 'longReadSeq';

interface Props {
  rows: ComparisonRow[];
  highlightedColumns?: ComparisonColumn[];
  highlightedRows?: string[];
}

const { rows, highlightedColumns = [], highlightedRows = [] } = Astro.props;
const highlightedColumnSet = new Set(highlightedColumns);
const highlightedRowSet = new Set(highlightedRows);
const isColumnHighlighted = (column: ComparisonColumn) => highlightedColumnSet.has(column);
const isRowHighlighted = (row: ComparisonRow) =>
  row.highlighted === true || highlightedRowSet.has(row.characteristic);
---

<div class="article-comparison-table" role="region" aria-label="RNA-Seq, long-read sequencing, and PSeq comparison">
  <table>
    <thead>
      <tr>
        <th scope="col" data-highlight-column={isColumnHighlighted('characteristic') ? 'true' : undefined}>Characteristic</th>
        <th scope="col" data-highlight-column={isColumnHighlighted('pseq') ? 'true' : undefined}>PSeq</th>
        <th scope="col" data-highlight-column={isColumnHighlighted('rnaSeq') ? 'true' : undefined}>RNA-Seq</th>
        <th scope="col" data-highlight-column={isColumnHighlighted('longReadSeq') ? 'true' : undefined}>3<sup>rd</sup> Gen Long Read Seq</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr data-highlight-row={isRowHighlighted(row) ? 'true' : undefined}>
          <th scope="row" data-label="Characteristic" data-highlight-column={isColumnHighlighted('characteristic') ? 'true' : undefined}>{row.characteristic}</th>
          <td data-label="PSeq" data-highlight-column={isColumnHighlighted('pseq') ? 'true' : undefined}>{row.pseq}</td>
          <td data-label="RNA-Seq" data-highlight-column={isColumnHighlighted('rnaSeq') ? 'true' : undefined}>{row.rnaSeq}</td>
          <td data-label="3rd Gen Long Read Seq" data-highlight-column={isColumnHighlighted('longReadSeq') ? 'true' : undefined}>{row.longReadSeq}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
.article-comparison-table {
  margin: 0.25rem 0 1.5rem;
  overflow-x: auto;
}

.article-comparison-table table {
  width: 100%;
  min-width: 44rem;
  border-collapse: collapse;
  border: 1px solid #d8dce0;
  color: #111827;
  font-size: 0.95rem;
  line-height: 1.4;
}

.article-comparison-table th,
.article-comparison-table td {
  padding: 0.75rem 0.85rem;
  border: 1px solid #d8dce0;
  text-align: left;
  vertical-align: middle;
}

.article-comparison-table thead th {
  background: #16647d;
  color: #fff;
  font-weight: 700;
}

.article-comparison-table tbody th {
  width: 20%;
  font-weight: 700;
}

.article-comparison-table tbody tr:nth-child(odd) {
  background: #f7f8f8;
}

.article-comparison-table tbody tr:nth-child(even) {
  background: #fff;
}

.article-comparison-table tbody tr:nth-child(odd) > [data-highlight-column="true"] {
  background: #dff2ec;
}

.article-comparison-table tbody tr:nth-child(even) > [data-highlight-column="true"] {
  background: #edf8f4;
}

.article-comparison-table tbody tr[data-highlight-row="true"] > th,
.article-comparison-table tbody tr[data-highlight-row="true"] > td {
  background: #fff7e8;
}

.article-comparison-table tbody tr[data-highlight-row="true"] > [data-highlight-column="true"] {
  background: #d3ece3;
}

@media (max-width: 725px) {
  .article-comparison-table {
    overflow: visible;
  }

  .article-comparison-table table,
  .article-comparison-table thead,
  .article-comparison-table tbody,
  .article-comparison-table tr,
  .article-comparison-table th,
  .article-comparison-table td {
    display: block;
    min-width: 0;
    width: 100%;
  }

  .article-comparison-table table {
    border: 0;
    font-size: 0.92rem;
  }

  .article-comparison-table thead {
    display: none;
  }

  .article-comparison-table tr {
    margin: 0 0 1rem;
    border: 1px solid #d8dce0;
    background: #fff;
  }

  .article-comparison-table th,
  .article-comparison-table td {
    display: grid;
    grid-template-columns: minmax(8rem, 38%) minmax(0, 1fr);
    gap: 0.75rem;
    border: 0;
    border-bottom: 1px solid #e5e7eb;
  }

  .article-comparison-table tr > :last-child {
    border-bottom: 0;
  }

  .article-comparison-table th::before,
  .article-comparison-table td::before {
    content: attr(data-label);
    color: #4b5563;
    font-weight: 700;
  }

  .article-comparison-table tbody th {
    width: 100%;
    background: #16647d;
    color: #fff;
  }

  .article-comparison-table tbody th[data-highlight-column="true"] {
    background: #0f7894;
  }

  .article-comparison-table th::before,
  .article-comparison-table td::before {
    overflow-wrap: anywhere;
  }

  .article-comparison-table tbody th::before {
    color: #dceef4;
  }
}
</style>
