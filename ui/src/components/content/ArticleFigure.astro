---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  maxWidth?: string;
}

const {
  src,
  alt,
  caption,
  maxWidth = '50rem',
} = Astro.props;
---

<figure class="article-figure" style={`--article-figure-max-width: ${maxWidth}`}>
  <img src={src} alt={alt} loading="lazy" />
  {caption ? <figcaption>{caption}</figcaption> : null}
</figure>

<style>
.article-figure {
  display: grid;
  justify-items: center;
  gap: 0.65rem;
  margin: 1rem 0 1.5rem;
}

.article-figure img {
  display: block;
  width: 100%;
  max-width: var(--article-figure-max-width);
  height: auto;
}

.article-figure figcaption {
  max-width: var(--article-figure-max-width);
  color: #4b5563;
  font-size: 0.9rem;
  line-height: 1.45;
  text-align: center;
}
</style>
