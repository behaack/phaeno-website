---
import { Image } from 'astro:assets';
---
<div class="new-seq-category">
  <div class="category-container">
    <div class="date">1986</div>
    <div class="category">
      <div class="category-text-wide">Sanger Sequencing</div>
      <div class="category-text-narrow">Sanger</div>
    </div>
  </div>
  <div class="image">
    <Image src="/images/right-arrow.webp" height={20} width={20} alt="right-arrow" />
  </div>
  <div class="category-container">
    <div class="date">2005</div>
    <div class="category">
      <div class="category-text-wide">Next Generation Sequencing<br/>(NGS)</div>
      <div class="category-text-narrow">NGS</div>
    </div>
  </div>
  <div class="image">
    <Image src="/images/right-arrow.webp" height={20} width={20} alt="right-arrow" />
  </div>  
  <div class="category-container">
    <div class="date">2011</div>
    <div class="category">
      <div class="category-text-wide">3rd Generation Sequencing</div>
      <div class="category-text-narrow">3rd Gen</div>      
    </div>
  </div>
  <div class="image">
    <Image src="/images/right-arrow.webp" height={20} width={20} alt="right-arrow" />
  </div>  
  <div class="category-container">
    <div class="date">2025</div>
    <div class="category-pseq">
      <div class="category-text-wide">Phased Sequencing</div>
      <div class="category-text-narrow">Phased Sequencing</div>
      <div class="category-text-2">PSeq™</div>
    </div>
    <div class="pseq-description">▪ NGS ▪ chemistry ▪ applied info theory ▪ software</div>
  </div>
</div>

<style>
  .new-seq-category {
    display: flex;
    gap: 2px;
  }

  .category-container {
    text-align: center;
  }

  .category {
    padding: 10px;
    width: 115px;
    height: 115px;
    background-color: black;
    color: white;
    border-radius: 15px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .category-text-wide {
    font-size: .9rem;
    display: inline-block;
  }

  .category-text-narrow {
    display: none;
    font-size: .85rem;
  }
  
  .category-text-2 {
    font-size:  1.4rem;
    margin-top: 5px;
  }

  .category-pseq {
    padding: 10px;
    width: 145px;
    height: 145px;
    background-color: rgb(216, 216, 165);
    color: black;
    font-weight: 800;
    border-radius: 15px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }  

  .date {
    font-size: 1.15rem;
    font-weight: 800;
  }

  .image {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: -55px;
  }

  .pseq-description {
    width: 145px;
    font-size: .875rem;
    font-weight: 800;
    text-align: center;
  }

  @media (max-width: 725px) {    
    .new-seq-category {
      display: flex;
      gap: 1px;
    }

    .category {
      width: 80px;
      height: 80px;
    }

    .category-pseq {
      padding: 7px;
      width: 105px;
      height: 105px;
    }     

    .category-text-wide {      
      display: none;
    }

    .category-text-narrow {
      display: inline-block;
    }   

    .category-text-2 {
      font-size:  1rem;
      margin-top: 3px;
    }    
    
    .pseq-description {
      width: 105px;
      font-size: .75rem;
    }

    .date {
      font-size: 1.05rem;
      font-weight: 800;
    }    
    
    .image {
      margin-top: -50px;
    }    
  }

  @media (max-width: 450px) {    
    .new-seq-category {
      gap: 5px;
    }
    .image {
      display: none;
    } 
  }  
</style>